# === تبعيات (كل مجلد له package.json خاص بيه) ===
node_modules/
frontend/node_modules/
backend/node_modules/

# === ملفات بيئة فيها أسرار حقيقية — الأمثلة (.env.example) لازم تفضل متسجلة ===
.env
.env.local
.env.*.local
frontend/.env
backend/.env
!**/.env.example

# === مخرجات بناء (بتتولّد من الكود، مش مصدر) ===
frontend/dist/
backend/dist/

# === مشروع Android بيتولّد أوتوماتيك من Capacitor (npx cap add android) —
# لو محتاج تتحكم في كود native يدوي فوقه، حطه في frontend/android-native/
# بدل ما تعدّل جوه android/ نفسه (اللي أصلاً بيتبني من الصفر كل مرة) ===
frontend/android/
frontend/ios/

# === Prisma (اختياري - سيب دي لو بتولّد الـ client أوتوماتيك بس) ===
backend/prisma/dev.db
backend/prisma/dev.db-journal

# === لوجات ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# === ملفات نظام/محررات ===
.DS_Store
.vscode/
.idea/
