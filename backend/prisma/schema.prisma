generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(cuid())
  username            String     @unique
  passwordHash        String
  isAdmin             Boolean    @default(false)
  isActive            Boolean    @default(true)
  tokenVersion        Int        @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginUserAgent  String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  lists               TodoList[]

  // ===== البريد الإلكتروني + استرجاع كلمة المرور =====
  // email nullable عشان الحسابات القديمة (النظام القديم اسم مستخدم+باسورد بس)
  // بتتسجّل من غير إيميل مبدئيًا لحد ما تكمّل "إعادة التأهيل" (rehabilitation)؛
  // أي حساب جديد من دلوقتي لازم يبقى معاه إيميل من لحظة التسجيل.
  email                       String?   @unique
  emailVerified               Boolean   @default(false)
  emailVerificationTokenHash  String?
  emailVerificationExpiresAt  DateTime?
  emailVerificationSentAt     DateTime?

  // بيتخزن الـ hash بتاع توكن استرجاع كلمة المرور بس (مش التوكن نفسه)،
  // زي ما بيتعمل بالظبط مع الباسورد — لو حصل تسريب لقاعدة البيانات، التوكن
  // الخام لسه محتاج معرفة الرابط الأصلي اللي اتبعت في الإيميل.
  resetTokenHash        String?
  resetTokenExpiresAt   DateTime?
  resetTokenRequestedAt DateTime?

  passwordUpdatedAt DateTime?

  // ===== إعادة تأهيل الحسابات القديمة (Username+Password بسيط، من غير إيميل) =====
  // legacyAccount: علامة تاريخية دايمة إن الحساب ده أصله من النظام القديم.
  // mustRehabilitate: طالما true، الحساب ممنوع يستخدم أي حاجة في الموقع غير
  // مسار إعادة التأهيل نفسه (شوف middleware/rehabilitationGate.ts)، وده بيتصفّر
  // تلقائيًا أول ما المستخدم يضيف إيميل صحيح وكلمة مرور جديدة قوية.
  legacyAccount    Boolean   @default(false)
  mustRehabilitate Boolean   @default(false)
  rehabilitatedAt  DateTime?

  // ===== التحقق بخطوتين (2FA / TOTP) — لحسابات الأدمن =====
  // twoFactorSecret بيتفعّل بس بعد ما الأدمن يأكّد بكود صحيح من تطبيق المصادقة.
  // pendingTwoFactorSecret ده تخزين مؤقت أثناء خطوة الإعداد نفسها، قبل التأكيد،
  // عشان لو الأدمن مسكرش الإعداد منعرفش نفعّل سر عشوائي محدش أكّده فعليًا.
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  pendingTwoFactorSecret String?
  // أكواد الاسترجاع بتتخزن مشفّرة (bcrypt) زي الباسورد بالظبط، وكل كود بيتحذف
  // من المصفوفة أول ما يُستخدم مرة واحدة (single-use)، لو الأدمن فقد جهاز المصادقة.
  twoFactorRecoveryCodes String[]  @default([])
  twoFactorEnabledAt     DateTime?

  @@index([createdAt])
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUsername  String
  targetUsername String?
  action         String
  ip             String?
  createdAt      DateTime @default(now())
}

// TodoList بتمثّل "المهمة الرئيسية" في واجهة المستخدم — عنوانها وأولويتها
// بيوصفوا الهدف الكبير، وكل عناصرها (TodoItem) دي المهام الفرعية اللي بتتحقق
// بيها المهمة الرئيسية خطوة خطوة.
model TodoList {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String     @default("قائمتي")
  priority  Priority   @default(NONE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     TodoItem[]

  @@unique([userId, title])
  @@index([userId])
}

// TodoItem بتمثّل "المهمة الفرعية" جوه المهمة الرئيسية.
model TodoItem {
  id        String    @id @default(cuid())
  listId    String
  list      TodoList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  content   String
  isDone    Boolean   @default(false)
  position  Int       @default(0)
  dueDate   DateTime?
  priority  Priority  @default(NONE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([listId])
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// إعدادات الموقع العامة، مخزّنة كـ key/value عشان نقدر نضيف إعدادات جديدة
// في المستقبل من غير ما نحتاج migration جديد لكل إعداد. لوحة تحكم الأدمن
// (تبويب "الإعدادات") هي المصدر الوحيد لتعديلها.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}
