generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(cuid())
  username            String     @unique
  passwordHash        String
  isAdmin             Boolean    @default(false)
  isActive            Boolean    @default(true)

  // ===== الملف الشخصي (اسم عرض، نبذة، أفتار) =====
  // منفصلين تمامًا عن username (اللي بيستخدم للدخول وثابت)، عشان المستخدم
  // يقدر يخصّص شكل ظهوره من غير ما يأثر على حسابه أو أي بيانات مرتبطة بيه.
  // avatarUrl: مسار صورة الأفتار اللي المستخدم رفعها بنفسه (بدل الألوان
  // والإيموجي القديمة) — لو null، الواجهة بتعرض الحرف الأول من اسمه بدلها.
  displayName String?
  bio         String?
  avatarUrl   String?
  tokenVersion        Int        @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginUserAgent  String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  lists               TodoList[]

  // ===== كود الاسترجاع (بديل مجاني/فوري لاسترجاع كلمة المرور بدل الإيميل) =====
  // بيتولّد كود عشوائي عالي الإنتروبيا مرة واحدة بعد التسجيل (أو بعد إعادة
  // التأهيل)، وبيتعرض للمستخدم مرة واحدة بس عشان يحفظه. المُخزّن هنا هو الـ
  // hash بتاعه فقط (SHA-256) — زي التوكنات المؤقتة بالظبط، مش الكود نفسه.
  // لو المستخدم نسي الباسورد بعدين، بيستخدم اسم المستخدم + الكود ده بدل ما
  // يستنى إيميل. كل مرة يتستخدم فيها الكود بينولّد كود جديد بيحل محل القديم.
  recoveryCodeHash      String?
  recoveryCodeCreatedAt DateTime?

  passwordUpdatedAt DateTime?

  // ===== إعادة تأهيل الحسابات القديمة (Username+Password بسيط، من غير كود استرجاع) =====
  // legacyAccount: علامة تاريخية دايمة إن الحساب ده أصله من النظام القديم.
  // mustRehabilitate: طالما true، الحساب ممنوع يستخدم أي حاجة في الموقع غير
  // مسار إعادة التأهيل نفسه (شوف middleware/rehabilitationGate.ts)، وده بيتصفّر
  // تلقائيًا أول ما المستخدم يختار كلمة مرور جديدة قوية ويستلم كود استرجاعه.
  // مفيش داعي لتشغيل أي سكريبت يدوي: أي حساب مالوش recoveryCodeHash لسه بيتكشف
  // تلقائيًا كحساب قديم أول ما يحاول يسجّل دخول (شوف routes/auth.ts).
  legacyAccount    Boolean   @default(false)
  mustRehabilitate Boolean   @default(false)
  rehabilitatedAt  DateTime?


  // ===== التحقق بخطوتين (2FA / TOTP) — لحسابات الأدمن =====
  // twoFactorSecret بيتفعّل بس بعد ما الأدمن يأكّد بكود صحيح من تطبيق المصادقة.
  // pendingTwoFactorSecret ده تخزين مؤقت أثناء خطوة الإعداد نفسها، قبل التأكيد،
  // عشان لو الأدمن مسكرش الإعداد منعرفش نفعّل سر عشوائي محدش أكّده فعليًا.
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  pendingTwoFactorSecret String?
  // أكواد الاسترجاع بتتخزن مشفّرة (bcrypt) زي الباسورد بالظبط، وكل كود بيتحذف
  // من المصفوفة أول ما يُستخدم مرة واحدة (single-use)، لو الأدمن فقد جهاز المصادقة.
  twoFactorRecoveryCodes String[]  @default([])
  twoFactorEnabledAt     DateTime?

  reminders         Reminder[]
  pushSubscriptions PushSubscription[]
  lifeAreas         LifeArea[]
  recurringTasks    RecurringTask[]

  @@index([createdAt])
}

// ===== مجالات الحياة (Life Areas) =====
// نظام تصنيف أعلى مستوى من TaskCategory (يومي/أسبوعي/إلخ): بدل ما يوصف
// "امتى" المهمة، بيوصف "في أي جانب من حياة المستخدم" هي (صحة، شغل، عائلة...).
// كل مستخدم بيعرّف مجالاته الخاصة بحرية كاملة (اسم + لون + أيقونة إيموجي أو
// صورة مرفوعة)، وكل مهمة رئيسية (TodoList) ممكن تتبع مجال واحد بس (اختياري).
// position بيحدد ترتيب العرض المخصص اللي المستخدم رتبه بنفسه.
model LifeArea {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  color String  @default("#1d6f73")
  // أيقونة إيموجي بسيطة (اختياري) — بتتجاهل في الواجهة لو فيه imageUrl مرفوع.
  icon  String?
  // صورة أيقونة مخصصة رفعها المستخدم من جهازه، بتحل محل الإيموجي في العرض.
  imageUrl String?
  position Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lists          TodoList[]
  recurringTasks RecurringTask[]

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, position])
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUsername  String
  targetUsername String?
  action         String
  ip             String?
  createdAt      DateTime @default(now())
}

// TodoList بتمثّل "المهمة الرئيسية" في واجهة المستخدم — عنوانها وأولويتها
// بيوصفوا الهدف الكبير، وكل عناصرها (TodoItem) دي المهام الفرعية اللي بتتحقق
// بيها المهمة الرئيسية خطوة خطوة.
model TodoList {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String     @default("قائمتي")
  priority  Priority   @default(NONE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     TodoItem[]
  reminders Reminder[]

  // ===== مؤقت المهمة الرئيسية (Task Timeline) =====
  // بيتفعّل بس لو الاتنين متحددين مع بعض (وقت البداية لازم يكون قبل وقت
  // النهاية — بيتفحص ده في السيرفر). الواجهة بتستخدمهم لعرض شريط زمني
  // متحرك بيتناقص لحد ما ينتهي الوقت، من غير ما تحتاج تستقصي السيرفر كل شوية
  // لأن الحساب كله بيتم في المتصفح اعتمادًا على الوقتين دول بس.
  startTime DateTime?
  endTime   DateTime?

  // ===== تصنيف المهمة الرئيسية (يومية/أسبوعية/شهرية/سنوية) =====
  // category بيبقى null لحد ما المستخدم يختار تصنيف بنفسه (غير مصنّفة).
  // targetYear بيتفعّل بس لما category يكون YEARLY، وبيتصفّر تلقائيًا لو
  // المستخدم غيّر التصنيف لحاجة تانية (شوف routes/lists.ts).
  category   TaskCategory?
  targetYear Int?

  // ===== مجال الحياة (Life Area) =====
  // اختياري تمامًا — null يعني "غير مصنّفة ضمن أي مجال". لو المجال اتحذف،
  // المهمة مش بتتحذف معاه، بس بترجع "بدون مجال" (onDelete: SetNull).
  lifeAreaId String?
  lifeArea   LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)

  // ===== الأرشفة (Archive) =====
  // archivedAt بتبقى null طول ما المهمة نشطة. أول ما كل مهامها الفرعية
  // تتحقق (isDone = true للكل، وفيه مهمة فرعية واحدة على الأقل)، السيرفر
  // بيسجّل توقيت الإكمال هنا تلقائيًا وبيك تختفي من القائمة الرئيسية
  // وتظهر في الأرشيف بدالها. لو المستخدم بعدين رجّع مهمة فرعية "غير منجزة"،
  // بترجع أوتوماتيك للقائمة النشطة (archivedAt بيترجع null) — شوف
  // lib/archive.ts. المستخدم كمان يقدر يؤرشف/يسترجع يدويًا في أي وقت.
  archivedAt DateTime?

  // ===== المهام المتكررة (Recurring Tasks) =====
  // لو المهمة الرئيسية دي "نسخة" اتولّدت تلقائيًا من قالب مهمة متكررة،
  // بيبقى ده الرابط بينها وبين القالب الأصلي (RecurringTask). لو القالب اتحذف،
  // النسخ القديمة بتفضل موجودة عادي (onDelete: SetNull) — الحذف بيوقف توليد
  // نسخ جديدة بس، مش بيمسح تاريخ اللي اتولّد فعلاً. occurrenceDate بيسجّل
  // "الدورة" اللي النسخة دي بتمثلها (مثلاً تاريخ يوم التكرار اليومي)، بيتستخدم
  // في تكوين عنوان مميز لكل نسخة عشان يفرق عن باقي النسخ (شوف lib/recurrence.ts).
  recurringTaskId String?
  recurringTask   RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  occurrenceDate  DateTime?

  @@unique([userId, title])
  @@index([userId])
  @@index([lifeAreaId])
  @@index([userId, archivedAt])
  @@index([recurringTaskId])
}

// TodoItem بتمثّل "المهمة الفرعية" جوه المهمة الرئيسية.
model TodoItem {
  id        String    @id @default(cuid())
  listId    String
  list      TodoList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  content   String
  isDone    Boolean   @default(false)
  position  Int       @default(0)
  dueDate   DateTime?
  priority  Priority  @default(NONE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  reminders Reminder[]

  @@index([listId])
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// تصنيف المهمة الرئيسية — بيحدد تحت أي قسم بتظهر المهمة (يومية/أسبوعية/
// شهرية/سنوية). المهام السنوية بس هي اللي بتستخدم targetYear في TodoList.
enum TaskCategory {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// وضع التذكير: CUSTOM = وقت مطلق يحدده المستخدم بنفسه، BEFORE_DUE = فترة
// زمنية (offsetMinutes) قبل موعد استحقاق المهمة نفسها (dueDate). لما يكون
// الوضع BEFORE_DUE بنحتفظ بالـ offset عشان لو المستخدم غيّر موعد الاستحقاق
// بعدين، نقدر نعيد حساب remindAt تلقائيًا من غير ما نفقد قصد المستخدم الأصلي.
enum ReminderMode {
  CUSTOM
  BEFORE_DUE
}

// تذكير واحد بيتبع إما مهمة رئيسية (listId) أو مهمة فرعية (itemId) — واحد
// بس مننهم لازم يكون متحدد (بيتفحص ده في السيرفر). المهمة الرئيسية معندهاش
// موعد استحقاق (dueDate)، فالتذكيرات بتاعتها بتقبل وضع CUSTOM بس، أما المهمة
// الفرعية فبتقبل الوضعين لو ليها موعد استحقاق محدد.
model Reminder {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listId String?
  list   TodoList? @relation(fields: [listId], references: [id], onDelete: Cascade)
  itemId String?
  item   TodoItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)

  mode          ReminderMode @default(CUSTOM)
  offsetMinutes Int?
  remindAt      DateTime
  message       String?

  isSent Boolean   @default(false)
  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([listId])
  @@index([itemId])
  @@index([remindAt, isSent])
}

// اشتراك Web Push واحد لكل جهاز/متصفح سجّل المستخدم دخوله منه. مستخدم واحد
// ممكن يكون عنده أكتر من اشتراك (موبايل + تابلت مثلًا)، فبنبعت الإشعار
// لكل الأجهزة المسجلة مرة واحدة.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// إعدادات الموقع العامة، مخزّنة كـ key/value عشان نقدر نضيف إعدادات جديدة
// في المستقبل من غير ما نحتاج migration جديد لكل إعداد. لوحة تحكم الأدمن
// (تبويب "الإعدادات") هي المصدر الوحيد لتعديلها.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// دورة تكرار المهمة المتكررة — نفس أسماء TaskCategory بالظبط وعن قصد، عشان
// المهمة الرئيسية المولّدة تلقائيًا تاخد نفس التصنيف (يومية/أسبوعية/شهرية/
// سنوية) من غير أي تحويل بين الاثنين (شوف lib/recurrence.ts).
enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// ===== قالب مهمة متكررة (Recurring Task Template) =====
// ده مش "مهمة رئيسية" بيشوفها المستخدم في شاشته الرئيسية — ده القالب/الإعداد
// اللي بيوصف إزاي وإمتى تتولّد نسخة (TodoList) جديدة تلقائيًا. كل قالب محفوظ
// في مكانه الخاص (شاشة "المهام المتكررة") عشان المستخدم يقدر يرجعله ويعدّل
// عليه في أي وقت من غير ما يأثر على النسخ اللي اتولّدت خلاص.
// interval بيسمح بتخصيص دورة التكرار (مثلاً كل يومين لو frequency=DAILY
// و interval=2، أو كل 3 أسابيع لو frequency=WEEKLY و interval=3).
// nextRunAt هو المصدر الوحيد اللي الجدولة (lib/recurringTaskScheduler.ts)
// بتعتمد عليه لمعرفة امتى تولّد النسخة الجاية، وبيتقدّم تلقائيًا بعد كل توليد.
model RecurringTask {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String
  priority Priority @default(NONE)

  lifeAreaId String?
  lifeArea   LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)

  frequency RecurrenceFrequency
  interval  Int                 @default(1)

  // أول تاريخ تبدأ منه دورة التكرار — هو نفسه المرجع اللي كل الدورات الجاية
  // بتتحسب بالإضافة عليه (شوف addRecurrenceInterval في lib/recurrence.ts).
  startDate DateTime

  // إيقاف مؤقت بدون حذف — القالب بيفضل محفوظ بكل إعداداته، بس مفيش نسخ
  // جديدة بتتولّد لحد ما المستخدم يرجّعه يشتغل تاني.
  isActive Boolean @default(true)

  lastGeneratedAt DateTime?
  nextRunAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          RecurringTaskItem[]
  generatedLists TodoList[]

  @@index([userId])
  @@index([isActive, nextRunAt])
}

// مهمة فرعية "قالب" — بتتنسخ لكل نسخة جديدة تتولّد من القالب (TodoItem جديد
// لكل واحدة). التعديل عليها هنا بيأثر بس على النسخ الجاية، مش النسخ القديمة
// اللي اتولّدت خلاص (زي أي قالب طبيعي).
model RecurringTaskItem {
  id              String        @id @default(cuid())
  recurringTaskId String
  recurringTask   RecurringTask @relation(fields: [recurringTaskId], references: [id], onDelete: Cascade)

  content  String
  priority Priority @default(NONE)
  position Int      @default(0)

  @@index([recurringTaskId])
}
