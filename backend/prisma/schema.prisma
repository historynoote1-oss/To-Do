generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(cuid())
  username            String     @unique
  passwordHash        String
  isAdmin             Boolean    @default(false)
  isActive            Boolean    @default(true)
  tokenVersion        Int        @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginUserAgent  String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  lists               TodoList[]

  // ===== التحقق بخطوتين (2FA / TOTP) — لحسابات الأدمن =====
  // twoFactorSecret بيتفعّل بس بعد ما الأدمن يأكّد بكود صحيح من تطبيق المصادقة.
  // pendingTwoFactorSecret ده تخزين مؤقت أثناء خطوة الإعداد نفسها، قبل التأكيد،
  // عشان لو الأدمن مسكرش الإعداد منعرفش نفعّل سر عشوائي محدش أكّده فعليًا.
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  pendingTwoFactorSecret String?
  // أكواد الاسترجاع بتتخزن مشفّرة (bcrypt) زي الباسورد بالظبط، وكل كود بيتحذف
  // من المصفوفة أول ما يُستخدم مرة واحدة (single-use)، لو الأدمن فقد جهاز المصادقة.
  twoFactorRecoveryCodes String[]  @default([])
  twoFactorEnabledAt     DateTime?

  @@index([createdAt])
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUsername  String
  targetUsername String?
  action         String
  ip             String?
  createdAt      DateTime @default(now())
}

model TodoList {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String     @default("قائمتي")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     TodoItem[]

  @@unique([userId, title])
  @@index([userId])
}

model TodoItem {
  id        String    @id @default(cuid())
  listId    String
  list      TodoList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  content   String
  isDone    Boolean   @default(false)
  position  Int       @default(0)
  dueDate   DateTime?
  priority  Priority  @default(NONE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([listId])
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
}

// سجل تحديثات الموقع — مصمم عشان يستحمل عدد ضخم من التحديثات (مئات الآلاف)
// مع بحث وتصفح سريعين، وتحرير كامل من لوحة تحكم الأدمن.
model Update {
  id          String   @id @default(cuid())
  version     String? // رقم إصدار اختياري، مثلاً "0.4"
  emoji       String   @default("✨")
  title       String
  features    String[] // نقاط التحديث
  howToTitle  String? // عنوان قسم "كيفية الاستخدام" (لو موجود)
  howToSteps  String[] // خطوات "كيفية الاستخدام"
  authorName  String   @default("فريق الموقع") // اسم الشخص/الفريق البشري اللي كتب التحديث
  pinned      Boolean  @default(false) // تحديث مثبّت فوق الكل بغض النظر عن تاريخه
  isPublished Boolean  @default(true) // مسودة لسه مش منشورة لو false
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // فهرس مركّب بيخلي الترتيب والتصفح بالـ cursor (keyset pagination) سريع
  // حتى مع مئات الآلاف من الصفوف، بدل الاعتماد على OFFSET اللي بيبطّئ مع الحجم الكبير.
  @@index([isPublished, pinned, publishedAt, id])
  @@index([version])
}
