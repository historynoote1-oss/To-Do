generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String     @id @default(cuid())
  username            String     @unique
  passwordHash        String
  isAdmin             Boolean    @default(false)
  isActive            Boolean    @default(true)

  // ===== الملف الشخصي (اسم عرض، نبذة، أفتار) =====
  // منفصلين تمامًا عن username (اللي بيستخدم للدخول وثابت)، عشان المستخدم
  // يقدر يخصّص شكل ظهوره من غير ما يأثر على حسابه أو أي بيانات مرتبطة بيه.
  // avatarUrl: مسار صورة الأفتار اللي المستخدم رفعها بنفسه (بدل الألوان
  // والإيموجي القديمة) — لو null، الواجهة بتعرض الحرف الأول من اسمه بدلها.
  displayName String?
  bio         String?
  avatarUrl   String?
  tokenVersion        Int        @default(0)
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginUserAgent  String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  lists               TodoList[]

  // ===== كود الاسترجاع (بديل مجاني/فوري لاسترجاع كلمة المرور بدل الإيميل) =====
  // بيتولّد كود عشوائي عالي الإنتروبيا مرة واحدة بعد التسجيل (أو بعد إعادة
  // التأهيل)، وبيتعرض للمستخدم مرة واحدة بس عشان يحفظه. المُخزّن هنا هو الـ
  // hash بتاعه فقط (SHA-256) — زي التوكنات المؤقتة بالظبط، مش الكود نفسه.
  // لو المستخدم نسي الباسورد بعدين، بيستخدم اسم المستخدم + الكود ده بدل ما
  // يستنى إيميل. كل مرة يتستخدم فيها الكود بينولّد كود جديد بيحل محل القديم.
  recoveryCodeHash      String?
  recoveryCodeCreatedAt DateTime?

  passwordUpdatedAt DateTime?

  // ===== إعادة تأهيل الحسابات القديمة (Username+Password بسيط، من غير كود استرجاع) =====
  // legacyAccount: علامة تاريخية دايمة إن الحساب ده أصله من النظام القديم.
  // mustRehabilitate: طالما true، الحساب ممنوع يستخدم أي حاجة في الموقع غير
  // مسار إعادة التأهيل نفسه (شوف middleware/rehabilitationGate.ts)، وده بيتصفّر
  // تلقائيًا أول ما المستخدم يختار كلمة مرور جديدة قوية ويستلم كود استرجاعه.
  // مفيش داعي لتشغيل أي سكريبت يدوي: أي حساب مالوش recoveryCodeHash لسه بيتكشف
  // تلقائيًا كحساب قديم أول ما يحاول يسجّل دخول (شوف routes/auth.ts).
  legacyAccount    Boolean   @default(false)
  mustRehabilitate Boolean   @default(false)
  rehabilitatedAt  DateTime?


  // ===== التحقق بخطوتين (2FA / TOTP) — لحسابات الأدمن =====
  // twoFactorSecret بيتفعّل بس بعد ما الأدمن يأكّد بكود صحيح من تطبيق المصادقة.
  // pendingTwoFactorSecret ده تخزين مؤقت أثناء خطوة الإعداد نفسها، قبل التأكيد،
  // عشان لو الأدمن مسكرش الإعداد منعرفش نفعّل سر عشوائي محدش أكّده فعليًا.
  twoFactorEnabled       Boolean   @default(false)
  twoFactorSecret        String?
  pendingTwoFactorSecret String?
  // أكواد الاسترجاع بتتخزن مشفّرة (bcrypt) زي الباسورد بالظبط، وكل كود بيتحذف
  // من المصفوفة أول ما يُستخدم مرة واحدة (single-use)، لو الأدمن فقد جهاز المصادقة.
  twoFactorRecoveryCodes String[]  @default([])
  twoFactorEnabledAt     DateTime?

  @@index([createdAt])
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  adminUsername  String
  targetUsername String?
  action         String
  ip             String?
  createdAt      DateTime @default(now())
}

// TodoList بتمثّل "المهمة الرئيسية" في واجهة المستخدم — عنوانها وأولويتها
// بيوصفوا الهدف الكبير، وكل عناصرها (TodoItem) دي المهام الفرعية اللي بتتحقق
// بيها المهمة الرئيسية خطوة خطوة.
model TodoList {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String     @default("قائمتي")
  priority  Priority   @default(NONE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     TodoItem[]

  @@unique([userId, title])
  @@index([userId])
}

// TodoItem بتمثّل "المهمة الفرعية" جوه المهمة الرئيسية.
model TodoItem {
  id        String    @id @default(cuid())
  listId    String
  list      TodoList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  content   String
  isDone    Boolean   @default(false)
  position  Int       @default(0)
  dueDate   DateTime?
  priority  Priority  @default(NONE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([listId])
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// إعدادات الموقع العامة، مخزّنة كـ key/value عشان نقدر نضيف إعدادات جديدة
// في المستقبل من غير ما نحتاج migration جديد لكل إعداد. لوحة تحكم الأدمن
// (تبويب "الإعدادات") هي المصدر الوحيد لتعديلها.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}
