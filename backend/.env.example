# رابط الاتصال المُجمَّع (pooled) — فيه -pooler في اسم الـ host — بيستخدمه التطبيق وقت التشغيل
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&connect_timeout=15"

# رابط الاتصال المباشر (direct) — من غير -pooler — بتستخدمه أوامر migrate بس
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
PORT=3001
