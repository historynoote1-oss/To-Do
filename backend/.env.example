# Railway بيولّد المتغير ده تلقائيًا لو ضفت PostgreSQL كإضافة في نفس المشروع
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# نص عشوائي طويل يُستخدم لتوقيع جلسات الدخول (JWT). غيّره لأي نص عشوائي طويل بتاعك
JWT_SECRET=change_this_to_a_long_random_string

# رابط الفرونت إند بتاعك من Vercel (عشان CORS)، مثال: https://todo.vercel.app
FRONTEND_URL=

PORT=3001

# ===== إشعارات الجهاز (Web Push) لنظام التذكيرات =====
# ولّد الزوج ده مرة واحدة بالأمر: npx web-push generate-vapid-keys
# نفس الـ VAPID_PUBLIC_KEY لازم يتحط برضو في frontend/.env كـ VITE_VAPID_PUBLIC_KEY
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
